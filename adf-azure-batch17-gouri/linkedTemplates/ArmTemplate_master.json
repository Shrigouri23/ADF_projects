{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-azure-batch17-gouri"
		},
		"ls_HttpServer_web_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_HttpServer_web'"
		},
		"ls_adls_batch17_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_batch17'"
		},
		"ls_source_AzureSqlDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_source_AzureSqlDatabase'"
		},
		"ls_HttpServer_web_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://wise.com/gb/currency-converter/eur-to-inr-rate"
		},
		"ls_HttpServer_web_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "shrigouri"
		},
		"ls_adls_batch17_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsazurebatch17gouri.dfs.core.windows.net"
		},
		"ls_source_AzureSqlDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azurebatch17-gouri.database.windows.net"
		},
		"ls_source_AzureSqlDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azuresqldbdev"
		},
		"ls_source_AzureSqlDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "shrigouri"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-azure-batch17-gouri_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_HttpServer_web_password": {
						"value": "[parameters('ls_HttpServer_web_password')]"
					},
					"ls_adls_batch17_accountKey": {
						"value": "[parameters('ls_adls_batch17_accountKey')]"
					},
					"ls_source_AzureSqlDatabase_password": {
						"value": "[parameters('ls_source_AzureSqlDatabase_password')]"
					},
					"ls_HttpServer_web_properties_typeProperties_url": {
						"value": "[parameters('ls_HttpServer_web_properties_typeProperties_url')]"
					},
					"ls_HttpServer_web_properties_typeProperties_userName": {
						"value": "[parameters('ls_HttpServer_web_properties_typeProperties_userName')]"
					},
					"ls_adls_batch17_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_batch17_properties_typeProperties_url')]"
					},
					"ls_source_AzureSqlDatabase_properties_typeProperties_server": {
						"value": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_server')]"
					},
					"ls_source_AzureSqlDatabase_properties_typeProperties_database": {
						"value": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_database')]"
					},
					"ls_source_AzureSqlDatabase_properties_typeProperties_userName": {
						"value": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-azure-batch17-gouri_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-azure-batch17-gouri_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-azure-batch17-gouri_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-azure-batch17-gouri_ArmTemplate_1')]"
			]
		}
	]
}