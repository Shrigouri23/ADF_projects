					"server": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_server')]",
					"database": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_source_AzureSqlDatabase_properties_typeProperties_userName')]",
					"password": {
